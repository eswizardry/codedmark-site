---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'CodeDMark — Software, marked good.',
  description = 'CodeDMark is a software studio in Thailand. From microcontrollers to mobile — we design, build, and test software that ships on time and holds up after. C, Qt, Flutter, and a healthy obsession with tests.',
} = Astro.props;
---
<!doctype html>
<html lang="en" data-theme="light">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://codedmark.com" />
  <meta name="twitter:card" content="summary_large_image" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600;700&family=IBM+Plex+Sans+Thai:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <!-- Theme + language detection — runs before first paint -->
  <script is:inline>
    (function () {
      // Theme
      try { var t = localStorage.getItem('cdm-theme'); if (t) document.documentElement.setAttribute('data-theme', t); } catch (e) {}
      // Language
      try {
        var l = localStorage.getItem('cdm-lang');
        window.__cdmLang = l || ((navigator.language || '').toLowerCase().startsWith('th') ? 'th' : 'en');
      } catch (e) { window.__cdmLang = 'en'; }
    })();
  </script>
</head>
<body>
  <slot />
  <!-- i18n translations + apply on DOMContentLoaded -->
  <script is:inline>
    (function () {
      var LANG_KEY = 'cdm-lang';
      var enCache = new Map();
      var enHtmlCache = new Map();

      var TH = {
        // nav
        'nav.work': 'ผลงาน',
        'nav.services': 'บริการ',
        'nav.stack': 'เทคโนโลยี',
        'nav.about': 'เกี่ยวกับเรา',
        'nav.contact': 'ติดต่อเรา',
        'nav.blog': 'บล็อก',
        'nav.cta': 'เริ่มโปรเจกต์',
        // hero
        'hero.eyebrow': 'สตูดิโอซอฟต์แวร์ · ประเทศไทย',
        'hero.h1': 'ซอฟต์แวร์<br><span class="g">ที่ดีจริง</span>',
        'hero.lead': 'ตั้งแต่ไมโครคอนโทรลเลอร์ไปจนถึงแอปมือถือ <b>CodeDMark</b> ออกแบบ พัฒนา และทดสอบซอฟต์แวร์ที่ส่งมอบตรงเวลา แถมยังอ่านง่ายและต่อยอดได้สบายเมื่อส่งต่อให้วิศวกรคนถัดไป เราถนัดทั้ง C, Qt, Flutter และใส่ใจเรื่องการทดสอบเป็นพิเศษ',
        'hero.cta1': 'เริ่มโปรเจกต์',
        'hero.cta2': 'ดูผลงานของเรา',
        // strip
        'strip.label': 'เราเชี่ยวชาญด้าน',
        // services
        'svc.eyebrow': 'สิ่งที่เราทำ',
        'svc.h2': 'สตูดิโอเดียว ครบทั้งสายงาน — ตั้งแต่ระดับชิปจนถึงหน้าจอ',
        'svc.sub': 'เราพาผลิตภัณฑ์จากภาพร่างบนกระดาษ ไปจนถึงงานที่ทดสอบเรียบร้อยและพร้อมส่งมอบ จะให้เราดูแลเฉพาะบางส่วน หรือยกให้ทั้งหมดเลยก็ได้',
        'svc.mobile.title': 'แอปมือถือ',
        'svc.mobile.desc': 'แอปข้ามแพลตฟอร์มด้วย Flutter โค้ดชุดเดียวใช้ได้ทั้ง iOS และ Android ให้ความรู้สึกเหมือนแอปเนทีฟ และใช้งานออฟไลน์ได้',
        'svc.embedded.title': 'ระบบฝังตัวและเฟิร์มแวร์',
        'svc.embedded.desc': 'เฟิร์มแวร์แบบ bare-metal และ RTOS บนชิป Cortex-M ทั้งไดรเวอร์ การสื่อสาร การ bring-up บอร์ด และลอจิกที่ผ่านการทดสอบยูนิตมาแล้ว',
        'svc.web.title': 'เว็บแอปและเว็บไซต์',
        'svc.web.desc': 'เว็บไซต์และแดชบอร์ดแบบ static-first ที่โหลดเร็ว นำไป deploy ที่ไหนก็ได้ และทำคะแนน Lighthouse ออกมาเขียวสวยทุกหมวด',
        'svc.desktop.title': 'Desktop และ HMI',
        'svc.desktop.desc': 'หน้าจอ Qt/C++ สำหรับเครื่องมือวัด ตู้ kiosk และแผงควบคุมในโรงงาน เปิดเครื่องก็พร้อมใช้ทันที และทำงานต่อเนื่องได้นานหลายปี',
        'svc.edtech.title': 'EdTech และการเรียนรู้',
        'svc.edtech.desc': 'เครื่องมือการเรียนรู้ที่พร้อมใช้ในห้องเรียน ทั้งแบบฝึกที่ปรับตามผู้เรียน ระบบติดตามความก้าวหน้า และเนื้อหาที่ออกแบบมาเพื่อนักเรียนจริง',
        'svc.consulting.title': 'ที่ปรึกษาและตรวจสอบโค้ด',
        'svc.consulting.desc': 'เป็นสายตาคู่ที่สองให้คุณ ทั้งรีวิวสถาปัตยกรรม กู้ test coverage ที่หายไป และดันงานที่ค้างอยู่ให้ออกสู่ตลาดได้',
        // work
        'work.eyebrow': 'ผลงานที่คัดมา',
        'work.h2': 'สิ่งที่เราสร้าง ทดสอบ และส่งมอบ',
        'work.sub': 'ตัวอย่างผลงานบางส่วน ครอบคลุมทั้งมือถือ ระบบฝังตัว และเดสก์ท็อป',
        'work.case': 'กรณีศึกษา',
        // stack
        'stack.eyebrow': 'เทคโนโลยีและทักษะ',
        'stack.h2': 'เครื่องมือที่เราเลือกใช้',
        'stack.sub': 'ลงลึกในจุดที่สำคัญ และเรียบง่ายในส่วนที่เหลือ เราเลือกเครื่องมือที่เรียบๆ ไม่หวือหวา ผ่านการพิสูจน์มาแล้ว และทดสอบมันอย่างหนัก',
        'stack.mobile': 'มือถือ',
        'stack.embedded': 'ระบบฝังตัว',
        'stack.desktop': 'เดสก์ท็อปและเว็บ',
        'stack.quality': 'คุณภาพและการดูแลระบบ',
        // process
        'proc.eyebrow': 'วิธีการทำงาน',
        'proc.h2': 'ชัดเจน แม่นยำ พิสูจน์ได้',
        'proc.sub': 'ไม่มีศัพท์สวยหรู ไม่มีอะไรหักมุมทีหลัง วัดกันที่ตัวเลขมากกว่าคำพูด และมีหลักฐานก่อนจะรับปาก',
        'proc.scope': 'กำหนดขอบเขต',
        'proc.scope.desc': 'เรามองหาปัญหาที่แท้จริง ข้อจำกัด และนิยามของคำว่า “เสร็จ” โดยเขียนเป็นลายลักษณ์อักษรให้ชัด ก่อนลงมือเขียนโค้ดแม้แต่บรรทัดเดียว',
        'proc.build': 'พัฒนา',
        'proc.build.desc': 'ทำงานเป็นรอบสั้นๆ มีซอฟต์แวร์ที่ใช้งานได้ตั้งแต่เนิ่นๆ คุณเห็นความคืบหน้าทุกสัปดาห์ ไม่ใช่รอเป็นเดือนโดยไม่รู้ว่าข้างในเกิดอะไรขึ้น',
        'proc.test': 'ทดสอบ',
        'proc.test.desc': 'ทั้งทดสอบยูนิต ทดสอบการเชื่อมต่อ (integration) และทดสอบบนฮาร์ดแวร์จริงในจุดที่สำคัญ อะไรที่ผ่านมาตรฐานเราถึงเก็บไว้',
        'proc.ship': 'ส่งมอบ',
        'proc.ship.desc': 'ส่งมอบอย่างเป็นระบบ ทั้งไฟล์ที่ทดสอบแล้ว เอกสารประกอบ และโค้ดใน repo ที่วิศวกรคนต่อไปอ่านเข้าใจได้จริง — โค้ดดีมาก สมชื่อ',
        // about
        'about.eyebrow': 'เกี่ยวกับเรา',
        'about.h2': 'สตูดิโอเล็กๆ ที่ส่งงานได้เหมือนทีมใหญ่',
        'about.p1': '<b>CodeDMark</b> คือสตูดิโอซอฟต์แวร์จากประเทศไทย ชื่อของเราสื่อความหมายได้ทั้งสองภาษา ในภาษาอังกฤษหมายถึงเครื่องหมายของนักพัฒนาที่ฝากไว้บนผลงาน ส่วนในภาษาไทยก็คือ <b>“โค้ดดีมาก”</b> นั่นเอง',
        'about.p2': 'เราเติบโตมาจากงานระบบฝังตัว ที่ซึ่งบักเพียงตัวเดียวอาจหมายถึงการเรียกคืนสินค้าทั้งล็อต ไม่ใช่แค่แก้ hotfix ง่ายๆ การทดสอบสำหรับเราจึงไม่ใช่แค่ขั้นตอนหนึ่ง แต่เป็นนิสัย และวินัยนั้นก็ติดตัวเรามาถึงงานมือถือและเว็บด้วย',
        'about.p3': 'ก่อตั้งโดย <b>Bancha Rajainthong</b> เรารับงานเพียงไม่กี่โปรเจกต์ในแต่ละช่วง เพื่อให้คนที่วางขอบเขตงานให้คุณ เป็นคนเดียวกับที่ลงมือสร้างมันจริงๆ',
        'about.tested': 'ทดสอบแล้ว',
        'about.shipped': 'ส่งมอบแล้ว',
        'about.measured': 'วัดผลได้',
        'about.entity': 'นิติบุคคล',
        'about.registered': 'ชื่อจดทะเบียน',
        'about.focus': 'ความเชี่ยวชาญ',
        // contact
        'contact.eyebrow': 'เริ่มโปรเจกต์',
        'contact.h2': 'มีงานอยากให้<span class="g">เกิดขึ้นจริงไหม?</span>',
        'contact.p': 'เล่าให้เราฟังว่าคุณกำลังสร้างอะไรอยู่ แล้วเราจะตอบกลับแบบตรงไปตรงมา ทั้งขอบเขตงาน ระยะเวลา และนิยามของคำว่า “เสร็จ” โดยไม่มีศัพท์สวยหรูให้ปวดหัว',
        'contact.cta1': 'อีเมลหาเรา',
        // footer
        'footer.desc': 'ซอฟต์แวร์ที่ส่งมอบตรงเวลา และยังดูแลต่อได้ง่ายในระยะยาว ทั้งงานระบบฝังตัว มือถือ และเว็บ — พัฒนาและทดสอบในประเทศไทย',
        'footer.studio': 'สตูดิโอ',
        'footer.connect': 'ช่องทางติดต่อ',
        'footer.work': 'ผลงาน',
        'footer.services': 'บริการ',
        'footer.stack': 'เทคโนโลยี',
        'footer.about': 'เกี่ยวกับเรา',
      };

      function applyLang(lang) {
        document.documentElement.setAttribute('lang', lang === 'th' ? 'th' : 'en');
        document.documentElement.setAttribute('data-lang', lang);
        var lbl = document.getElementById('lang-label');
        if (lbl) lbl.textContent = lang === 'th' ? 'EN' : 'TH';

        document.querySelectorAll('[data-i18n]').forEach(function (el) {
          var key = el.getAttribute('data-i18n');
          if (lang === 'th' && TH[key] !== undefined) {
            if (!enCache.has(el)) enCache.set(el, el.textContent);
            el.textContent = TH[key];
          } else if (lang === 'en' && enCache.has(el)) {
            el.textContent = enCache.get(el);
          }
        });

        document.querySelectorAll('[data-i18n-html]').forEach(function (el) {
          var key = el.getAttribute('data-i18n-html');
          if (lang === 'th' && TH[key] !== undefined) {
            if (!enHtmlCache.has(el)) enHtmlCache.set(el, el.innerHTML);
            el.innerHTML = TH[key];
          } else if (lang === 'en' && enHtmlCache.has(el)) {
            el.innerHTML = enHtmlCache.get(el);
          }
        });
      }

      document.addEventListener('DOMContentLoaded', function () {
        applyLang(window.__cdmLang || 'en');
        var toggle = document.getElementById('lang-toggle');
        if (toggle) {
          toggle.addEventListener('click', function () {
            var next = window.__cdmLang === 'th' ? 'en' : 'th';
            window.__cdmLang = next;
            try { localStorage.setItem(LANG_KEY, next); } catch (e) {}
            applyLang(next);
          });
        }
      });
    })();
  </script>
</body>
</html>
