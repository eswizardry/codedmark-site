    <div class="top">
      <div>
        <a href="#top" class="brand">
          <Mark size={38} />
          CodeDMark<span class="dot">.</span>
        </a>
        <p class="fdesc" data-i18n="footer.desc">Software that ships on time and holds up after. Embedded, mobile, and web — built and tested in Thailand.</p>
      </div>
      <div class="cols">
        <div class="col">
          <h5 data-i18n="footer.studio">Studio</h5>
          <a href="#work" data-i18n="footer.work">Work</a>
          <a href="#services" data-i18n="footer.services">Services</a>
          <a href="#stack" data-i18n="footer.stack">Stack</a>
          <a href="#about" data-i18n="footer.about">About</a>
        </div>
        <div class="col">
          <h5 data-i18n="footer.connect">Connect</h5>
          <a href="mailto:eswizardry@gmail.com">Email</a>
          <a href="https://github.com/eswizardry" target="_blank" rel="noopener">GitHub</a>
          <a href="/blog/">Blog</a>
