---
import { getCollection } from 'astro:content';
import PhoneMock from './previews/PhoneMock.astro';
import TerminalMock from './previews/TerminalMock.astro';
import WindowMock from './previews/WindowMock.astro';
import BrowserMock from './previews/BrowserMock.astro';

const entries = (await getCollection('work')).sort((a, b) => a.data.order - b.data.order);

const previewMap = {
  phone: PhoneMock,
  terminal: TerminalMock,
  window: WindowMock,
  browser: BrowserMock,
} as const;
---
<section class="blk" id="work" style="background:var(--surface);border-top:1px solid var(--border);border-bottom:1px solid var(--border)">
  <div class="wrap">
    <div class="sec-head reveal">
      <div>
        <span class="eyebrow" data-i18n="work.eyebrow">Selected work</span>
        <h2 data-i18n="work.h2">Things we built, tested, and shipped.</h2>
      </div>
      <p class="sub" data-i18n="work.sub">A slice of the portfolio across mobile, embedded, and desktop.</p>
    </div>
    <div class="work-grid">
      {entries.map(entry => {
        const Preview = previewMap[entry.data.previewType];
        return (
          <div class="work reveal">
            {entry.data.screenshot
              ? (
                <div class="preview">
                  <img src={entry.data.screenshot} alt={entry.data.title} class="work-img" loading="lazy" />
                </div>
              )
              : <Preview />
            }
            <div class="meta">
              <span class="kicker">{entry.data.kicker}</span>
              <h3>{entry.data.title}</h3>
              <p>{entry.data.summary}</p>
              {entry.data.outcomes.length > 0 && (
                <ul class="work-outcomes">
                  {entry.data.outcomes.map(o => <li>{o}</li>)}
                </ul>
              )}
              <div class="stack">
                {entry.data.stack.map(s => <span>{s}</span>)}
              </div>
              <div class="work-cta">
                <a href={`/work/${entry.slug}/`} class="btn btn-ghost work-btn">
                  <span data-i18n="work.case">Case study</span> <span class="arr">→</span>
                </a>
                {entry.data.link && (
                  <a href={entry.data.link} target="_blank" rel="noopener" class="btn btn-ghost work-btn">
                    {entry.data.linkLabel} <span>↗</span>
                  </a>
                )}
              </div>
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>
