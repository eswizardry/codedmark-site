<section class="blk" id="contact">
  <div class="wrap">
    <div class="contact reveal">
      <div class="grid-bg"></div>
      <div class="inner">
        <span class="eyebrow" data-i18n="contact.eyebrow">Start a project</span>
        <h2 data-i18n-html="contact.h2">Have something to <span class="g">ship?</span></h2>
        <p data-i18n="contact.p">
          Tell us what you're building. We'll come back with a plain, precise answer —
          scope, timeline, and what "done" looks like. No buzzwords.
        </p>
        <div class="cta">
          <a
            href="mailto:eswizardry@gmail.com?subject=Project%20enquiry%20%E2%80%94%20CodeDMark"
            class="btn btn-primary"
          ><span data-i18n="contact.cta1">Email us</span> <span class="arr">→</span></a>
          <a href="https://github.com/eswizardry" target="_blank" rel="noopener" class="btn btn-ghost">
            GitHub
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
